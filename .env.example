# ── Copy this file to .env and fill in your values ──────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# PostgreSQL connection (used inside Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ragdb

# RAG pipeline
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
RAG_RERANK_TOP_N=3

# App
DEBUG=false
