# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# PostgreSQL — keep this as-is when running with docker-compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ragdb

# RAG pipeline defaults (optional — these are the defaults)
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
RAG_RERANK_TOP_N=3

# Set to true for verbose SQL and LLM request logs
DEBUG=false
